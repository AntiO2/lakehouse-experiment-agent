#!/bin/bash
# ============================================================
# lakehouse-experiment-agent: Local Secrets Override
# Copy this file to env.local.sh (git-ignored) and fill in
# your actual credentials and environment-specific values.
# ============================================================

# ---- AWS Credentials ----
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# ---- S3 ----
export S3_BUCKET="home-dongyang"

# ---- MySQL (Pixels metadata) ----
export MYSQL_HOST=""
export MYSQL_PORT="3306"
export MYSQL_USER="pixels"
export MYSQL_PASSWORD=""

# ---- Cluster hosts (private IPs) ----
export HOST_RETINA=""
export HOST_FLINK=""
export HOST_TRINO=""
export HOST_SINK=""

# ---- Trino cluster nodes (space separated private IPs) ----
export TRINO_WORKERS=""

# ---- Data generation scale factors ----
# Space-separated: sf100 sf1000 sf1333 (HyBench) / wh10000 (CHBenchmark)
export HYBENCH_SCALES="sf100"
export CHBENCH_WAREHOUSES=""

# ---- External Repository Paths ----
export PIXELS_BENCHMARK_REPO="$HOME/projects/pixels-benchmark"
export PIXELS_SINK_REPO="$HOME/pixels-sink"
export PIXELS_LANCE_REPO="$HOME/pixels-lance"
export PIXELS_SPARK_REPO="$HOME/projects/pixels-spark"
export CH_BENCHMARK_REPO="$HOME/projects/CH-benchmark"
